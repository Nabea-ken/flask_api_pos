# Copy this file to .env and fill in your values (never commit .env).
#
#   copy .env.example .env

SECRET_KEY=replace-with-a-long-random-string
JWT_SECRET_KEY=replace-with-a-different-long-random-string
# If PASSWORD has special characters (@ # / etc.), encode them (e.g. @ → %40).
# You can use 127.0.0.1 instead of localhost if you hit odd connection issues.
SQLALCHEMY_DATABASE_URI=postgresql://USER:PASSWORD@127.0.0.1:5432/DATABASE_NAME

# Comma-separated list of allowed browser origins, or * for any (dev only).
# Example: http://127.0.0.1:5500,http://localhost:8080
CORS_ORIGINS=*
