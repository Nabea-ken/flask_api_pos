{
  "info": {
    "name": "flask-api-pos",
    "description": "Import this file in Postman: File → Import → select this JSON.\nSet collection variable `base_url` if your server is not on 127.0.0.1:5000 (use your ngrok URL without a trailing slash for public testing).\nRun Register or Login first; the test script saves `access_token` for the other requests.\nA pre-request script adds `ngrok-skip-browser-warning: true` so ngrok free tier does not block API calls.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "pm.request.headers.upsert({ key: 'ngrok-skip-browser-warning', value: 'true' });"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:5000"
    },
    {
      "key": "access_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var j = pm.response.json();",
                  "    if (j.access_token) { pm.collectionVariables.set('access_token', j.access_token); }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"your-password-here\"\n}"
            },
            "url": "{{base_url}}/register",
            "description": "Creates a user. Change email if you already registered. On 201, saves access_token to collection variable."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var j = pm.response.json();",
                  "    if (j.access_token) { pm.collectionVariables.set('access_token', j.access_token); }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"your-password-here\"\n}"
            },
            "url": "{{base_url}}/login",
            "description": "Use after Register or with an existing user. On 200, saves access_token."
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List products (GET)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/products"
          }
        },
        {
          "name": "Create product (POST)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Coffee\",\n  \"amount\": 3.50\n}"
            },
            "url": "{{base_url}}/products"
          }
        }
      ]
    },
    {
      "name": "Sales",
      "item": [
        {
          "name": "List sales (GET)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/sales"
          }
        },
        {
          "name": "Create sale + payment (POST)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": 1,\n  \"trans_code\": \"TX-1001\",\n  \"trans_amount\": \"3.50\",\n  \"phone_paid\": \"+15551234567\"\n}"
            },
            "url": "{{base_url}}/sales",
            "description": "Set product_id to an id returned from Create product."
          }
        }
      ]
    }
  ]
}
